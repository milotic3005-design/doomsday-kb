{
  "name": "doomsday-kb",
  "version": "0.1.0",
  "description": "Doomsday Knowledge Base - Offline AI Survival Computer",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prebuild:ollama": "node scripts/copy-ollama.js",
    "package": "npm run prebuild:ollama && npm run build && electron-builder --win",
    "package:dir": "npm run build && electron-builder --win --dir",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["offline", "ai", "knowledge-base", "survival", "electron"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "apache-arrow": "^18.1.0",
    "express": "^5.2.1",
    "gpt-tokenizer": "^3.4.0",
    "marked": "^17.0.4",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
